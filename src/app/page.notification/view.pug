div(class="relative w-full h-full overflow-hidden")
    div(class="w-full h-full overflow-y-auto")
        div(class="max-w-4xl mx-auto px-5 py-4")
            //- 헤더
            div(class="flex items-center justify-between mb-4")
                div(class="flex items-center gap-2")
                    i(class="ti ti-bell text-[20px] text-blue-500")
                    h1(class="text-lg font-semibold text-neutral-900") 알림함
                button(*ngIf="items.length > 0", type="button",
                    class="text-xs text-neutral-500 hover:text-blue-600 transition-colors px-3 py-1 rounded-md hover:bg-neutral-100",
                    (click)="markAllRead()") 모두 읽음

            //- 탭
            div(class="flex border-b border-neutral-200 mb-4")
                button(type="button",
                    class="px-4 py-2 text-[13px] font-medium border-b-2 transition-colors -mb-px",
                    [ngClass]="tab === 'all' ? 'border-blue-500 text-blue-600' : 'border-transparent text-neutral-500 hover:text-neutral-700'",
                    (click)="switchTab('all')") 전체 알림
                button(type="button",
                    class="px-4 py-2 text-[13px] font-medium border-b-2 transition-colors -mb-px ml-1",
                    [ngClass]="tab === 'issue' ? 'border-blue-500 text-blue-600' : 'border-transparent text-neutral-500 hover:text-neutral-700'",
                    (click)="switchTab('issue')") 이슈
                button(type="button",
                    class="px-4 py-2 text-[13px] font-medium border-b-2 transition-colors -mb-px ml-1",
                    [ngClass]="tab === 'calendar' ? 'border-blue-500 text-blue-600' : 'border-transparent text-neutral-500 hover:text-neutral-700'",
                    (click)="switchTab('calendar')") 캘린더

            //- 로딩
            ng-container(*ngIf="loading")
                div(class="flex items-center justify-center py-16")
                    div(class="animate-spin rounded-full h-6 w-6 border-2 border-neutral-300 border-t-blue-500")

            ng-container(*ngIf="!loading")
                //- 결과 요약
                div(class="flex items-center justify-between mb-2")
                    span(class="text-xs text-neutral-400") 총 {{total}}건
                    ng-container(*ngIf="total > dump")
                        span(class="text-xs text-neutral-400") {{page}} / {{maxPage()}} 페이지

                //- 비어있을 때
                ng-container(*ngIf="items.length === 0")
                    div(class="bg-white rounded-lg border border-neutral-200")
                        div(class="flex flex-col items-center justify-center py-16 text-center")
                            i(class="ti ti-bell-off text-3xl text-neutral-300 mb-2")
                            p(class="text-sm text-neutral-500") 알림이 없습니다

                //- 목록
                ng-container(*ngIf="items.length > 0")
                    div(class="bg-white rounded-lg border border-neutral-200 overflow-hidden")
                        div(class="divide-y divide-neutral-100")
                            ng-container(*ngFor="let item of items")
                                div(class="flex items-start px-4 py-3 cursor-pointer transition-colors",
                                    [ngClass]="item.is_read ? 'bg-neutral-50 opacity-60 hover:bg-neutral-100' : 'hover:bg-blue-50'",
                                    (click)="onClickItem(item)")
                                    div(class="flex items-center mr-3 mt-1")
                                        i(class="ti text-[18px]",
                                            [ngClass]="[typeIcon(item.type).icon, typeIcon(item.type).cls]")
                                    div(class="flex-1 min-w-0")
                                        //- 이슈 타입
                                        ng-container(*ngIf="item.ref_type === 'issue'")
                                            div(class="flex items-center gap-2 flex-wrap")
                                                span(*ngIf="!item.is_read",
                                                    class="size-2 rounded-full bg-blue-500 shrink-0")
                                                span(*ngIf="item.status",
                                                    class="text-xs rounded-full px-2 py-0.5 shrink-0 ring-1 ring-inset",
                                                    [ngClass]="displayStatus(item.status).cls") {{displayStatus(item.status).text}}
                                                span(*ngIf="item.is_mentioned",
                                                    class="text-xs rounded-full px-2 py-0.5 shrink-0 bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-200") 멘션
                                                span(class="text-[13px] font-medium truncate",
                                                    [ngClass]="item.is_read ? 'text-neutral-500' : 'text-neutral-800'") {{item.title}}
                                            div(class="flex items-center mt-0.5 text-xs text-neutral-400")
                                                span(*ngIf="item.project?.title",
                                                    class="truncate max-w-[120px]") {{item.project.title}}
                                                span(*ngIf="item.project?.title", class="mx-1") ·
                                                span {{displayDate(item.created)}}
                                                ng-container(*ngIf="item.planend")
                                                    span(class="mx-1") ·
                                                    span([ngClass]="isOverdue(item.planend) ? 'text-red-500 font-medium' : ''") 마감 {{displayShortDate(item.planend)}}
                                        //- 캘린더/기타 알림 타입
                                        ng-container(*ngIf="item.ref_type !== 'issue'")
                                            div(class="flex items-center gap-2 flex-wrap")
                                                span(*ngIf="!item.is_read",
                                                    class="size-2 rounded-full bg-blue-500 shrink-0")
                                                span(class="text-xs rounded-full px-2 py-0.5 shrink-0 ring-1 ring-inset",
                                                    [ngClass]="item.ref_type === 'calendar' ? 'bg-green-50 text-green-700 ring-green-200' : 'bg-blue-50 text-blue-700 ring-blue-200'") {{typeLabel(item.type)}}
                                                span(class="text-[13px] font-medium truncate",
                                                    [ngClass]="item.is_read ? 'text-neutral-500' : 'text-neutral-800'") {{item.title}}
                                            div(class="flex items-center mt-0.5 text-xs text-neutral-400",
                                                *ngIf="item.message")
                                                span(class="truncate") {{item.message}}
                                            div(class="flex items-center mt-0.5 text-xs text-neutral-400")
                                                span(*ngIf="item.project?.title",
                                                    class="truncate max-w-[120px]") {{item.project.title}}
                                                span(*ngIf="item.project?.title", class="mx-1") ·
                                                span {{displayDate(item.created)}}

                //- 페이지네이션
                ng-container(*ngIf="total > dump")
                    div(class="flex items-center justify-between mt-3")
                        span(class="text-xs text-neutral-500") {{page}} / {{maxPage()}} 페이지
                        div(class="flex items-center gap-2")
                            button(type="button",
                                class="px-3 py-1 rounded text-xs border border-neutral-300 text-neutral-600 hover:bg-neutral-100 transition-colors disabled:opacity-40",
                                [disabled]="page <= 1",
                                (click)="prevPage()") 이전
                            button(type="button",
                                class="px-3 py-1 rounded text-xs border border-neutral-300 text-neutral-600 hover:bg-neutral-100 transition-colors disabled:opacity-40",
                                [disabled]="page >= maxPage()",
                                (click)="nextPage()") 다음

    //- 이슈 상세 팝업
    ng-container(*ngIf="issue.id")
        div(class="absolute inset-0 z-40 hidden md:block", style="background:rgba(0,0,0,0.1)")
        div(class="absolute inset-0 md:inset-x-8 md:inset-y-4 lg:inset-x-16 lg:inset-y-8 z-50")
            div(class="relative w-full h-full overflow-hidden md:rounded-xl")
                wiz-portal-works-project-issueboard-issue([issue]="issue",
                    [isMovable]="false",
                    [hidden]="!issue.loaded")
