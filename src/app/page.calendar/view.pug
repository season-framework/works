div(class="w-full h-full flex overflow-hidden bg-white")
    //- 좌측: 캘린더 영역
    div(class="flex-1 min-w-0 flex flex-col overflow-hidden")
        //- 헤더: 월 네비게이션
        div(class="flex items-center justify-between px-6 py-4 border-b border-neutral-200")
            div(class="flex items-center gap-3")
                button(class="p-1 rounded-md hover:bg-neutral-100 transition-colors", (click)="prevMonth()")
                    i(class="ti ti-chevron-left text-lg text-neutral-600")
                h2(class="text-lg font-semibold text-neutral-900 min-w-[120px] text-center") {{monthLabel}}
                button(class="p-1 rounded-md hover:bg-neutral-100 transition-colors", (click)="nextMonth()")
                    i(class="ti ti-chevron-right text-lg text-neutral-600")
                button(class="ml-2 px-3 py-1 text-xs font-medium text-neutral-600 bg-neutral-100 rounded-md hover:bg-neutral-200 transition-colors",
                    (click)="goToday()") 오늘
            div(class="flex items-center gap-2")
                button(class="flex items-center gap-1.5 px-3 py-1 text-xs font-medium rounded-md transition-colors",
                    [ngClass]="myOnly ? 'bg-blue-500 text-white' : 'text-neutral-600 bg-neutral-100 hover:bg-neutral-200'",
                    (click)="toggleMyOnly()")
                    i(class="ti ti-user text-sm")
                    | 내 일정만

        //- 캘린더 그리드
        div(class="flex-1 min-h-0 overflow-auto")
            div(class="min-h-full")
                //- 요일 헤더
                div(class="grid grid-cols-7 border-b border-neutral-200 bg-neutral-50 sticky top-0 z-10")
                    ng-container(*ngFor="let name of dayNames; let i = index")
                        div(class="py-2 text-center text-xs font-medium uppercase tracking-wider",
                            [ngClass]="i === 0 ? 'text-red-400' : (i === 6 ? 'text-blue-400' : 'text-neutral-500')") {{name}}

                //- 주별 행
                ng-container(*ngFor="let week of weeks")
                    div(class="grid grid-cols-7 border-b border-neutral-100")
                        ng-container(*ngFor="let cell of week; let i = index")
                            div(class="min-h-[100px] border-r border-neutral-100 last:border-r-0 p-1 hover:bg-neutral-50/50 transition-colors",
                                [ngClass]="{'bg-blue-50/30': cell.date === today, 'opacity-40': !cell.currentMonth}",
                                (dragover)="onDragOver($event)",
                                (drop)="onDrop($event, cell)")
                                //- 날짜 숫자
                                div(class="flex items-center justify-between px-1")
                                    span(class="text-xs font-medium",
                                        [ngClass]="{'text-red-500': i === 0, 'text-blue-500': i === 6, 'text-neutral-700': i > 0 && i < 6, 'bg-blue-500 text-white rounded-full w-5 h-5 flex items-center justify-center': cell.date === today}") {{cell.day}}
                                //- 이벤트 목록
                                div(class="mt-1 space-y-0.5")
                                    ng-container(*ngFor="let ev of cell.events; let ei = index")
                                        div(*ngIf="ei < 3",
                                            class="text-xs px-1.5 py-0.5 rounded truncate text-white cursor-pointer hover:opacity-80 transition-opacity",
                                            [style.background-color]="getEventColor(ev)",
                                            draggable="true",
                                            (dragstart)="onDragStart($event, ev)",
                                            (click)="openEvent(ev); $event.stopPropagation()")
                                            | {{ev.title}}
                                        div(*ngIf="ei === 3",
                                            class="text-xs px-1.5 text-neutral-400")
                                            | +{{cell.events.length - 3}}건

    //- 우측: 프로젝트 필터 사이드바
    div(class="w-[260px] flex-shrink-0 border-l border-neutral-200 flex flex-col bg-neutral-50 overflow-hidden")
        div(class="px-4 py-3 border-b border-neutral-200")
            div(class="flex items-center justify-between")
                span(class="text-[13px] font-semibold text-neutral-700") 프로젝트 필터
                input(type="checkbox",
                    class="w-3.5 h-3.5 rounded border-neutral-300 cursor-pointer",
                    [checked]="allProjectsChecked",
                    (change)="toggleAllProjects()")

        div(class="flex-1 min-h-0 overflow-y-auto px-4 py-3 space-y-0.5")
            ng-container(*ngFor="let p of displayProjects")
                div(class="flex items-center gap-2 py-1")
                    input(type="checkbox",
                        class="w-3.5 h-3.5 rounded border-neutral-300 cursor-pointer",
                        [checked]="projectFilters[p.id] !== false",
                        (change)="toggleProject(p.id)")
                    span(class="text-[13px] text-neutral-700 truncate flex-1") {{p.title || p.namespace}}
                    span(*ngIf="p.status === 'close'",
                        class="text-[10px] text-neutral-400 flex-shrink-0") 종료

        //- 종료된 프로젝트 토글
        div(class="px-4 py-2.5 border-t border-neutral-200")
            label(class="flex items-center gap-2 cursor-pointer")
                input(type="checkbox",
                    class="w-3.5 h-3.5 rounded border-neutral-300 cursor-pointer",
                    [checked]="showClosedProjects",
                    (change)="toggleShowClosed()")
                span(class="text-xs text-neutral-500") 종료된 프로젝트 포함

    //- 모달 오버레이 (읽기 전용)
    div(*ngIf="showModal && selectedEvent", class="fixed inset-0 z-[9999] flex items-center justify-center")
        div(class="absolute inset-0 bg-black/30", (click)="closeModal()")
        div(class="relative bg-white rounded-lg shadow-xl w-full max-w-lg mx-4 overflow-hidden")
            //- 헤더
            div(class="flex items-center justify-between px-5 py-4 border-b border-neutral-200")
                h3(class="text-sm font-semibold text-neutral-900") 일정 상세
                button(class="p-1 rounded-md hover:bg-neutral-100 transition-colors", (click)="closeModal()")
                    i(class="ti ti-x text-lg text-neutral-400")

            //- 본문
            div(class="px-5 py-4 space-y-4 max-h-[60vh] overflow-y-auto")
                div
                    label(class="block text-xs font-medium text-neutral-500 mb-1") 제목
                    p(class="text-sm text-neutral-900") {{selectedEvent.title}}
                div(*ngIf="selectedEvent.description")
                    label(class="block text-xs font-medium text-neutral-500 mb-1") 설명
                    p(class="text-sm text-neutral-700 whitespace-pre-wrap") {{selectedEvent.description}}
                div(class="flex gap-4")
                    div
                        label(class="block text-xs font-medium text-neutral-500 mb-1") 시작
                        p(class="text-sm text-neutral-900") {{selectedEvent.start?.substring(0, selectedEvent.all_day ? 10 : 16)}}
                    div
                        label(class="block text-xs font-medium text-neutral-500 mb-1") 종료
                        p(class="text-sm text-neutral-900") {{selectedEvent.end?.substring(0, selectedEvent.all_day ? 10 : 16)}}
                div(*ngIf="selectedEvent.all_day")
                    span(class="inline-flex items-center px-2 py-0.5 text-xs font-medium bg-neutral-100 text-neutral-600 rounded-full") 종일 일정
                div(*ngIf="selectedEvent.project_title")
                    label(class="block text-xs font-medium text-neutral-500 mb-1") 프로젝트
                    p(class="text-sm text-neutral-900") {{selectedEvent.project_title}}
                div(*ngIf="selectedEvent.category?.name")
                    label(class="block text-xs font-medium text-neutral-500 mb-1") 카테고리
                    div(class="flex items-center gap-2")
                        div(class="w-2.5 h-2.5 rounded-full",
                            [style.background-color]="selectedEvent.category?.color || '#3b82f6'")
                        p(class="text-sm text-neutral-900") {{selectedEvent.category.name}}
                div(*ngIf="selectedEvent.attendees?.length")
                    label(class="block text-xs font-medium text-neutral-500 mb-1") 참가자
                    div(class="flex flex-wrap gap-1")
                        ng-container(*ngFor="let att of selectedEvent.attendees")
                            span(class="inline-flex items-center px-2 py-0.5 text-xs bg-neutral-100 text-neutral-700 rounded-full")
                                | {{att.user_name || att.user_id}}

            //- 푸터
            div(class="flex items-center justify-between px-5 py-3 border-t border-neutral-200 bg-neutral-50")
                div
                div(class="flex gap-2")
                    button(class="px-4 py-1.5 text-sm font-medium text-neutral-600 bg-white border border-neutral-200 rounded-md hover:bg-neutral-50 transition-colors",
                        (click)="closeModal()") 닫기
                    button(class="px-4 py-1.5 text-sm font-medium text-white bg-blue-500 rounded-md hover:bg-blue-600 transition-colors",
                        (click)="navigateToProject(selectedEvent)") 프로젝트로 이동
