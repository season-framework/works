div(class="flex-1 min-h-0 overflow-y-auto")
    div(class="max-w-6xl mx-auto px-8 py-8")
        //- 헤더
        div(class="mb-8")
            h1(class="text-2xl font-bold text-neutral-900") 대시보드
            p(class="mt-1 text-sm text-neutral-500") 내 프로젝트와 작업 현황을 한눈에 확인하세요

        //- 로딩
        ng-container(*ngIf="!loaded")
            div(class="grid gap-4 grid-cols-1 md:grid-cols-2")
                div(class="bg-white rounded-lg border border-neutral-200 p-6", *ngFor="let i of [1,2,3,4]")
                    div(class="bg-neutral-100 rounded h-5 mb-4 w-1/3 animate-pulse")
                    div(class="bg-neutral-100 rounded h-4 mb-2 w-2/3 animate-pulse")
                    div(class="bg-neutral-100 rounded h-4 w-1/2 animate-pulse")

        ng-container(*ngIf="loaded")
            //- 이슈 요약 카운트
            div(class="grid gap-4 mb-6 grid-cols-3")
                div(class="bg-white rounded-lg border border-neutral-200 p-4 text-center cursor-pointer hover:bg-neutral-50 transition-colors", (click)="navigateIssues()")
                    div(class="text-2xl font-bold text-neutral-700") {{issues.counts.open}}
                    div(class="text-xs text-neutral-500 mt-1") 대기
                div(class="bg-white rounded-lg border border-neutral-200 p-4 text-center cursor-pointer hover:bg-neutral-50 transition-colors", (click)="navigateIssues()")
                    div(class="text-2xl font-bold text-blue-600") {{issues.counts.work}}
                    div(class="text-xs text-neutral-500 mt-1") 진행
                div(class="bg-white rounded-lg border border-neutral-200 p-4 text-center cursor-pointer hover:bg-neutral-50 transition-colors", (click)="navigateIssues()")
                    div(class="text-2xl font-bold text-green-600") {{issues.counts.finish}}
                    div(class="text-xs text-neutral-500 mt-1") 완료

            //- ═══════════════════════════════════════════════
            //- 내 캘린더 섹션 (전체 너비)
            //- ═══════════════════════════════════════════════
            div(class="mb-4")
                div(class="bg-white rounded-lg border border-neutral-200 overflow-hidden")
                    //- 헤더
                    div(class="flex items-center justify-between px-5 py-4 border-b border-neutral-200")
                        div(class="flex items-center gap-2")
                            i(class="ti ti-calendar-event text-[18px] text-neutral-400")
                            span(class="text-base font-medium text-neutral-800") 내 일정
                        div(class="flex items-center gap-2")
                            button(type="button",
                                class="p-1 rounded hover:bg-neutral-100 text-neutral-400 hover:text-neutral-600 transition-colors",
                                (click)="calPrev()")
                                i(class="ti ti-chevron-left text-[16px]")
                            span(class="text-sm font-medium text-neutral-700 min-w-[100px] text-center") {{calMonthLabel()}}
                            button(type="button",
                                class="p-1 rounded hover:bg-neutral-100 text-neutral-400 hover:text-neutral-600 transition-colors",
                                (click)="calNext()")
                                i(class="ti ti-chevron-right text-[16px]")
                            button(type="button",
                                class="ml-1 px-2 py-1 rounded text-xs text-neutral-500 hover:bg-neutral-100 transition-colors",
                                (click)="calToday()") 오늘

                    //- 캘린더 그리드
                    div(class="p-4")
                        //- 로딩
                        ng-container(*ngIf="calLoading")
                            div(class="flex items-center justify-center py-8")
                                div(class="animate-spin rounded-full h-6 w-6 border-2 border-neutral-300 border-t-blue-500")

                        ng-container(*ngIf="!calLoading")
                            //- 요일 헤더
                            div(class="grid grid-cols-7 mb-1")
                                div(class="text-center text-xs font-medium text-red-400 py-1") 일
                                div(class="text-center text-xs font-medium text-neutral-400 py-1") 월
                                div(class="text-center text-xs font-medium text-neutral-400 py-1") 화
                                div(class="text-center text-xs font-medium text-neutral-400 py-1") 수
                                div(class="text-center text-xs font-medium text-neutral-400 py-1") 목
                                div(class="text-center text-xs font-medium text-neutral-400 py-1") 금
                                div(class="text-center text-xs font-medium text-blue-400 py-1") 토

                            //- 날짜 그리드
                            div(*ngFor="let week of calWeeks",
                                class="grid grid-cols-7")
                                ng-container(*ngFor="let cell of week; let i = index")
                                    div(class="relative min-h-[72px] border-t border-neutral-100 p-1 cursor-pointer hover:bg-neutral-50 transition-colors",
                                        [class.bg-blue-50]="calSelectedDate === cell.date && cell.isCurrentMonth",
                                        (click)="selectDate(cell)")
                                        //- 날짜 숫자
                                        ng-container(*ngIf="cell.isCurrentMonth")
                                            div(class="flex items-center justify-center")
                                                span(class="text-xs w-6 h-6 flex items-center justify-center rounded-full",
                                                    [class.bg-blue-500]="cell.isToday",
                                                    [class.text-white]="cell.isToday",
                                                    [class.font-bold]="cell.isToday",
                                                    [class.text-red-400]="i === 0 && !cell.isToday",
                                                    [class.text-blue-400]="i === 6 && !cell.isToday",
                                                    [class.text-neutral-600]="i > 0 && i < 6 && !cell.isToday") {{cell.day}}
                                            //- 이벤트 도트
                                            div(class="mt-1 space-y-0.5 overflow-hidden", style="max-height: 42px")
                                                ng-container(*ngFor="let ev of cell.events; let ei = index")
                                                    ng-container(*ngIf="ei < 3")
                                                        div(class="flex items-center gap-1 px-0.5")
                                                            div(class="w-1.5 h-1.5 rounded-full shrink-0",
                                                                [ngStyle]="{'background-color': calEventColor(ev)}")
                                                            span(class="text-[10px] text-neutral-600 truncate leading-tight") {{ev.title}}
                                                ng-container(*ngIf="cell.events.length > 3")
                                                    div(class="text-[10px] text-neutral-400 px-0.5") +{{cell.events.length - 3}}

                            //- 선택된 날짜 일정 상세
                            ng-container(*ngIf="calSelectedDate")
                                div(class="mt-3 border-t border-neutral-200 pt-3")
                                    div(class="flex items-center gap-2 mb-2")
                                        span(class="text-sm font-medium text-neutral-700") {{calSelectedDate}}
                                        span(class="text-xs text-neutral-400") {{calSelectedEvents.length}}건
                                    ng-container(*ngIf="calSelectedEvents.length === 0")
                                        div(class="text-sm text-neutral-400 py-4 text-center") 일정이 없습니다
                                    div(class="space-y-2")
                                        ng-container(*ngFor="let ev of calSelectedEvents")
                                            div(class="flex items-start gap-3 p-3 bg-neutral-50 rounded-lg hover:bg-neutral-100 transition-colors cursor-pointer",
                                                [routerLink]="'/project/' + ev.project_namespace + '/calendar'")
                                                div(class="w-1 h-full min-h-[36px] rounded-full shrink-0 mt-0.5",
                                                    [ngStyle]="{'background-color': calEventColor(ev)}")
                                                div(class="flex-1 min-w-0")
                                                    div(class="flex items-center gap-2")
                                                        span(class="text-sm font-medium text-neutral-800 truncate") {{ev.title}}
                                                        ng-container(*ngIf="ev.all_day")
                                                            span(class="text-[10px] bg-neutral-200 text-neutral-500 rounded px-1") 종일
                                                    div(class="flex items-center gap-2 mt-1 text-xs text-neutral-400")
                                                        span(class="truncate max-w-[120px]") {{ev.project_title}}
                                                        ng-container(*ngIf="ev.category")
                                                            span ·
                                                            span {{ev.category.name}}
                                                        span ·
                                                        span {{calFormatDateRange(ev)}}

            div(class="grid gap-4 grid-cols-1 md:grid-cols-2")
                //- 내 프로젝트 섹션
                div(class="bg-white rounded-lg border border-neutral-200 overflow-hidden")
                    div(class="flex items-center justify-between px-5 py-4 border-b border-neutral-200")
                        div(class="flex items-center gap-2")
                            i(class="ti ti-folder text-[18px] text-neutral-400")
                            span(class="text-base font-medium text-neutral-800") 내 프로젝트
                        span(class="text-xs text-neutral-400") {{projects.length}}건
                    div(class="divide-y divide-neutral-100", style="max-height: 360px; overflow-y: auto")
                        ng-container(*ngIf="projects.length === 0")
                            div(class="flex flex-col items-center justify-center py-12 text-center")
                                i(class="ti ti-folder-off text-4xl text-neutral-300 mb-3")
                                p(class="text-sm text-neutral-500") 참여 중인 프로젝트가 없습니다
                        ng-container(*ngFor="let item of projects")
                            a(class="flex items-center px-5 py-3 cursor-pointer hover:bg-neutral-50 transition-colors", [routerLink]="'/project/' + item.namespace")
                                div(class="shrink-0 w-9 h-9 rounded-md bg-neutral-100 border border-neutral-200 bg-contain bg-center bg-cover bg-no-repeat", [ngStyle]="{'background-image': 'url(' + item.icon + ')'}")
                                div(class="flex-1 ml-3 min-w-0")
                                    div(class="flex items-center")
                                        span(class="text-sm font-medium text-neutral-800 truncate") {{item.title}}
                                        span(class="text-xs rounded-full px-2 py-0.5 ml-2 shrink-0 ring-1 ring-inset", [ngClass]="displayRole(item.role).cls") {{displayRole(item.role).text}}
                                    div(class="text-xs text-neutral-400 mt-0.5") {{displayDate(item.updated)}}

                //- 배정된 이슈 섹션
                div(class="bg-white rounded-lg border border-neutral-200 overflow-hidden")
                    div(class="flex items-center justify-between px-5 py-4 border-b border-neutral-200")
                        div(class="flex items-center gap-2")
                            i(class="ti ti-message-circle text-[18px] text-neutral-400")
                            span(class="text-base font-medium text-neutral-800") 배정된 이슈
                        a(class="text-xs text-blue-600 cursor-pointer hover:underline", routerLink="/issues") 전체보기
                    div(class="divide-y divide-neutral-100", style="max-height: 360px; overflow-y: auto")
                        ng-container(*ngIf="issues.recent.length === 0")
                            div(class="flex flex-col items-center justify-center py-12 text-center")
                                i(class="ti ti-message-circle-off text-4xl text-neutral-300 mb-3")
                                p(class="text-sm text-neutral-500") 배정된 이슈가 없습니다
                        ng-container(*ngFor="let item of issues.recent")
                            a(class="flex items-start px-5 py-3 cursor-pointer hover:bg-neutral-50 transition-colors", routerLink="/issues")
                                div(class="flex-1 min-w-0")
                                    div(class="flex items-center")
                                        span(class="text-xs rounded-full px-2 py-0.5 shrink-0 ring-1 ring-inset", [ngClass]="displayStatus(item.status).cls") {{displayStatus(item.status).text}}
                                        span(class="text-sm text-neutral-700 truncate ml-2") {{item.title}}
                                    div(class="flex items-center mt-1 text-xs text-neutral-400")
                                        span(class="truncate max-w-[120px]") {{item.project?.title}}
                                        span(class="mx-1") ·
                                        span {{displayDate(item.updated)}}
                                        ng-container(*ngIf="item.planend")
                                            span(class="mx-1") ·
                                            span([ngClass]="isOverdue(item.planend) ? 'text-red-500 font-medium' : ''") 마감 {{displayShortDate(item.planend)}}

                //- 내가 생성한 미완료 이슈
                div(class="bg-white rounded-lg border border-neutral-200 overflow-hidden")
                    div(class="flex items-center justify-between px-5 py-4 border-b border-neutral-200")
                        div(class="flex items-center gap-2")
                            i(class="ti ti-edit text-[18px] text-neutral-400")
                            span(class="text-base font-medium text-neutral-800") 내가 생성한 이슈
                        span(class="text-xs text-neutral-400") {{createdIssues.length}}건
                    div(class="divide-y divide-neutral-100", style="max-height: 360px; overflow-y: auto")
                        ng-container(*ngIf="createdIssues.length === 0")
                            div(class="flex flex-col items-center justify-center py-12 text-center")
                                i(class="ti ti-checkbox text-4xl text-neutral-300 mb-3")
                                p(class="text-sm text-neutral-500") 미완료 이슈가 없습니다
                        ng-container(*ngFor="let item of createdIssues")
                            a(class="flex items-start px-5 py-3 cursor-pointer hover:bg-neutral-50 transition-colors", routerLink="/issues")
                                div(class="flex-1 min-w-0")
                                    div(class="flex items-center")
                                        span(class="text-xs rounded-full px-2 py-0.5 shrink-0 ring-1 ring-inset", [ngClass]="displayStatus(item.status).cls") {{displayStatus(item.status).text}}
                                        span(class="text-sm text-neutral-700 truncate ml-2") {{item.title}}
                                    div(class="flex items-center mt-1 text-xs text-neutral-400")
                                        span(class="truncate max-w-[120px]") {{item.project?.title}}
                                        span(class="mx-1") ·
                                        span {{displayDate(item.updated)}}

                //- 최근 회의록 섹션
                div(class="bg-white rounded-lg border border-neutral-200 overflow-hidden")
                    div(class="flex items-center justify-between px-5 py-4 border-b border-neutral-200")
                        div(class="flex items-center gap-2")
                            i(class="ti ti-notes text-[18px] text-neutral-400")
                            span(class="text-base font-medium text-neutral-800") 최근 회의록
                        span(class="text-xs text-neutral-400") {{meetings.length}}건
                    div(class="divide-y divide-neutral-100", style="max-height: 360px; overflow-y: auto")
                        ng-container(*ngIf="meetings.length === 0")
                            div(class="flex flex-col items-center justify-center py-12 text-center")
                                i(class="ti ti-notes-off text-4xl text-neutral-300 mb-3")
                                p(class="text-sm text-neutral-500") 최근 회의록이 없습니다
                        ng-container(*ngFor="let item of meetings")
                            a(class="flex items-start px-5 py-3 cursor-pointer hover:bg-neutral-50 transition-colors", [routerLink]="'/project/' + item.project?.namespace + '/meeting'")
                                div(class="flex-1 min-w-0")
                                    div(class="flex items-center")
                                        span(class="text-sm text-neutral-700 truncate") {{item.title}}
                                    div(class="flex items-center mt-1 text-xs text-neutral-400")
                                        span(class="truncate max-w-[120px]") {{item.project?.title}}
                                        span(class="mx-1") ·
                                        span {{displayShortDate(item.meetdate)}}
                                        span(class="mx-1") ·
                                        span {{getUserName(item.user_id)}}

            //- 내 계획 섹션 (전체 너비)
            div(class="mt-4")
                div(class="bg-white rounded-lg border border-neutral-200 overflow-hidden")
                    div(class="flex items-center justify-between px-5 py-4 border-b border-neutral-200")
                        div(class="flex items-center gap-2")
                            i(class="ti ti-calendar text-[18px] text-neutral-400")
                            span(class="text-base font-medium text-neutral-800") 내 계획
                        span(class="text-xs text-neutral-400") {{plans.length}}건
                    div(class="divide-y divide-neutral-100", style="max-height: 300px; overflow-y: auto")
                        ng-container(*ngIf="plans.length === 0")
                            div(class="flex flex-col items-center justify-center py-12 text-center")
                                i(class="ti ti-calendar-off text-4xl text-neutral-300 mb-3")
                                p(class="text-sm text-neutral-500") 진행 중인 계획이 없습니다
                        ng-container(*ngFor="let item of plans")
                            a(class="flex items-center px-5 py-3 cursor-pointer hover:bg-neutral-50 transition-colors", [routerLink]="'/project/' + item.project?.namespace + '/info'")
                                div(class="flex-1 min-w-0")
                                    div(class="flex items-center")
                                        span(class="text-xs rounded-full px-2 py-0.5 shrink-0 ring-1 ring-inset", [ngClass]="displayPlanStatus(item.status).cls") {{displayPlanStatus(item.status).text}}
                                        span(class="text-sm text-neutral-700 truncate ml-2") {{item.title}}
                                    div(class="flex items-center mt-1 text-xs text-neutral-400")
                                        span(class="truncate max-w-[120px]") {{item.project?.title}}
                                        ng-container(*ngIf="item.start || item.end")
                                            span(class="mx-1") ·
                                            span {{displayShortDate(item.start)}} ~ {{displayShortDate(item.end)}}
