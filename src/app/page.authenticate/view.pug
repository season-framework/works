.fixed.inset-0.overflow-hidden(*ngIf="this.returnTo != 'notset'")
    .w-full.h-full.flex

        //- 왼쪽: 브랜드 영역 (모바일 숨김)
        .hidden.relative.overflow-hidden(class="md:flex md:w-1/2 lg:w-[55%]")
            .absolute.inset-0.brand-gradient
            .absolute.inset-0.flex.flex-col.items-center.justify-center.z-10.px-12
                .mb-8
                    img.h-10(src="/assets/portal/season/brand/logo-white.svg", alt="Logo")
                h1.text-white.font-bold.text-center.leading-tight(class="text-2xl lg:text-3xl") 팀과 함께
                    br
                    | 더 나은 업무 경험을
                p.mt-4.text-center.font-light.leading-relaxed(class="text-white/70 text-sm lg:text-base max-w-[360px]") 프로젝트 관리, 위키, 캘린더를 하나의 공간에서 효율적으로 협업하세요.
            .absolute.rounded-full.border.opacity-20(class="w-[500px] h-[500px] -bottom-[200px] -left-[100px] border-white/30")
            .absolute.rounded-full.border.opacity-10(class="w-[300px] h-[300px] -top-[80px] -right-[60px] border-white/20")

        //- 오른쪽: 폼 영역
        .w-full.flex.items-center.justify-center.bg-white(class="md:w-1/2 lg:w-[45%]")
            .w-full.px-8.py-12(class="max-w-[400px]")

                //- 모바일 로고
                .flex.justify-center.mb-12(class="md:hidden")
                    img.h-8(src="/assets/portal/season/brand/logo-black.svg", alt="Logo")

                //- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                //- 로그인: 이메일 입력
                //- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                ng-container(*ngIf="view == 'login.email'")
                    .mb-10
                        h2.text-3xl.font-bold.text-zinc-900.tracking-tight 로그인
                        p.mt-3.text-base.text-zinc-400 업무 공간에 로그인하세요

                    .space-y-5
                        input.auth-input(type="text",
                            placeholder="이메일 주소",
                            [(ngModel)]="data.email",
                            (keydown.enter)="login()",
                            autofocus)

                        button.auth-btn-primary((click)="login()")
                            span 이메일로 계속하기
                            i.ti.ti-arrow-right.auth-btn-icon

                    .auth-divider.my-8
                        span 또는

                    wiz-portal-saml-providers

                    .mt-10.text-center
                        span.text-sm.text-zinc-400 계정이 없으신가요?
                        |  
                        a.ml-1.text-sm.font-semibold.text-blue-600.cursor-pointer.transition(class="hover:text-blue-700", (click)="join_start()") 회원가입

                //- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                //- 로그인: 비밀번호 입력
                //- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                ng-container(*ngIf="view == 'login.password'")
                    .mb-10
                        h2.text-3xl.font-bold.text-zinc-900.tracking-tight 비밀번호
                        .mt-3.inline-flex.items-center.gap-2.px-3.py-2.rounded-full.bg-zinc-100
                            i.ti.ti-mail.text-sm.text-zinc-500
                            span.text-sm.text-zinc-600 {{data.email}}

                    .space-y-5
                        input.auth-input(type="password",
                            placeholder="비밀번호 입력",
                            [(ngModel)]="data.password",
                            (keydown.enter)="login()")

                        button.auth-btn-primary((click)="login()")
                            span 로그인
                            i.ti.ti-arrow-right.auth-btn-icon

                    .mt-8.flex.items-center.justify-between
                        a.auth-link((click)="toLogin()")
                            i.ti.ti-chevron-left.text-base
                            span 이전
                        a.auth-link((click)="alert('준비중입니다', 'warning')") 비밀번호 찾기

                //- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                //- 회원가입: 이메일 입력
                //- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                ng-container(*ngIf="view == 'join.email'")
                    .mb-10
                        h2.text-3xl.font-bold.text-zinc-900.tracking-tight 회원가입
                        p.mt-3.text-base.text-zinc-400 이메일로 시작하세요

                    .space-y-5
                        input.auth-input(type="text",
                            placeholder="이메일 주소",
                            [(ngModel)]="data.email",
                            (keydown.enter)="join_email_check()",
                            autofocus)

                        button.auth-btn-primary((click)="join_email_check()")
                            span 이메일로 시작하기
                            i.ti.ti-arrow-right.auth-btn-icon

                    .mt-10.text-center
                        span.text-sm.text-zinc-400 이미 계정이 있으신가요?
                        |  
                        a.text-sm.font-semibold.text-blue-600.cursor-pointer.transition(class="hover:text-blue-700", (click)="toLogin()") 로그인

                //- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                //- 회원가입: 약관 동의
                //- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                ng-container(*ngIf="view == 'join.terms'")
                    .mb-8
                        h2.text-3xl.font-bold.text-zinc-900.tracking-tight 약관 동의
                        p.mt-3.text-base.text-zinc-400 서비스 이용을 위해 동의해주세요

                    .auth-terms-box
                        h4.font-semibold.text-zinc-700.text-sm 귀하가 시즌웍스 계정을 생성할 때 수집하는 정보
                        p.text-sm.text-zinc-500.mt-2
                            span.font-medium.text-zinc-600 수집하는 개인정보 항목 및 이용 목적:
                            |  시즌웍스는 계정의 생성 및 관리, 서비스의 제공 및 개선, 고객의 계정 또는 서비스 관련 의사소통 및 고객요청 대응을 위해 다음과 같은 데이터를 수집합니다.
                        ul.list-disc.pl-5.mt-2.space-y-1.text-sm.text-zinc-500
                            li 이름 및 연락처 데이터: 사용자의 성과 이름, 메일 주소, 전화번호 및 기타 유사한 연락처 데이터.
                            li 자격 증명: 비밀번호, 비밀번호 힌트 및 인증과 계정 액세스에 사용되는 유사한 보안 정보.
                            li 인구 통계학적 데이터: 나이, 성별, 국가, 선호하는 언어 등 사용자에 대한 데이터.
                        h4.font-semibold.text-zinc-700.text-sm.mt-4 개인정보의 보유 및 이용 기간
                        p.text-sm.text-zinc-500.mt-1 시즌웍스는 서비스 제공을 위해서, 또는 법적 의무 준수, 분쟁 해결, 계약 이행과 같은 다른 중요한 목적을 위해 필요한 기간 동안 데이터를 유지합니다.

                    button.auth-btn-primary.mt-6((click)="termsAccept()")
                        i.ti.ti-circle-check.text-lg.mr-2
                        span 동의하고 계속하기

                //- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                //- 회원가입: 이메일 인증
                //- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                ng-container(*ngIf="view == 'join.verify'")
                    .mb-10
                        h2.text-3xl.font-bold.text-zinc-900.tracking-tight 인증코드
                        .mt-3.inline-flex.items-center.gap-2.px-3.py-2.rounded-full.bg-zinc-100
                            i.ti.ti-mail-forward.text-sm.text-zinc-500
                            span.text-sm.text-zinc-600 {{data.email}}
                        p.mt-4.text-sm.text-zinc-400 이메일로 전송된 6자리 코드를 입력하세요

                    .space-y-5
                        input.auth-input.auth-input-code(type="text",
                            placeholder="000000",
                            autocomplete="off",
                            [(ngModel)]="data.onetimepass",
                            (keyup.enter)="emailVerify(data.email, data.onetimepass)")

                        button.auth-btn-primary((click)="emailVerify(data.email, data.onetimepass)")
                            span 인증 확인
                            i.ti.ti-arrow-right.auth-btn-icon

                    .mt-8.text-center
                        a.auth-link.justify-center((click)="emailAuthentication(data.email)")
                            i.ti.ti-refresh.text-base.mr-1
                            span 인증 메일 다시 보내기

                //- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                //- 회원가입: 정보 입력
                //- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                ng-container(*ngIf="view == 'join.userrequired'")
                    .mb-8
                        h2.text-3xl.font-bold.text-zinc-900.tracking-tight 기본 정보
                        p.mt-3.text-base.text-zinc-400 마지막 단계입니다

                    .space-y-4
                        .auth-input-group
                            .auth-input-label 이메일
                            input.auth-input.auth-input-disabled(type="text",
                                [(ngModel)]="data.email", disabled)

                        .auth-input-group
                            .auth-input-label 이름
                            input.auth-input(type="text",
                                placeholder="이름을 입력하세요",
                                autocomplete="off",
                                [(ngModel)]="data.name")

                        .auth-input-group
                            .auth-input-label 비밀번호
                            input.auth-input(type="password",
                                placeholder="8자 이상, 영문 + 숫자",
                                autocomplete="off",
                                [(ngModel)]="data.password")

                        .auth-input-group
                            .auth-input-label 비밀번호 확인
                            input.auth-input(type="password",
                                placeholder="비밀번호를 다시 입력하세요",
                                autocomplete="off",
                                [(ngModel)]="data.password_repeat")

                        .auth-input-group
                            .auth-input-label 휴대전화
                            input.auth-input(type="text",
                                placeholder="010-1234-5678",
                                autocomplete="off",
                                [(ngModel)]="data.mobile")

                    button.auth-btn-primary.mt-6((click)="join()")
                        span 가입 완료
                        i.ti.ti-check.auth-btn-icon
