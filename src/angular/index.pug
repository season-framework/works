doctype html
html(lang="en", class="overflow-hidden")
    head
        meta(charset="utf-8")
        title 시즌웍스
        base(href="/")
        meta(name='viewport' content='width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0')
        meta(http-equiv='X-UA-Compatible' content='ie=edge')

        link(rel="shortcut icon", href="/assets/portal/season/brand/icon.ico")
        link(rel="apple-touch-icon" sizes="72x72" href="/assets/portal/season/brand/icon-192.png")
        link(rel="apple-touch-icon" sizes="114x114" href="/assets/portal/season/brand/icon-192.png")
        link(rel="apple-touch-icon" sizes="192x192" href="/assets/portal/season/brand/icon-192.png")
        link(rel="apple-touch-icon" href="/assets/portal/season/brand/icon-192.png")
        link(rel="icon" sizes="72x72" href="/assets/portal/season/brand/icon.ico")
        link(rel="icon" sizes="114x114" href="/assets/portal/season/brand/icon.ico")
        link(rel="icon" sizes="192x192" href="/assets/portal/season/brand/icon.ico")
        link(rel="icon" sizes="57x57" href="/assets/portal/season/brand/icon.ico")

        meta(name='msapplication-TileColor' content='#6C8DF6')
        meta(name='theme-color' content='#FFFFFF')
        meta(name='apple-mobile-web-app-status-bar-style' content='#FFFFFF')
        meta(name='apple-mobile-web-app-capable' content='yes')
        meta(name='apple-mobile-web-app-title' content='시즌웍스')
        meta(name='mobile-web-app-capable' content='yes')
        meta(name='HandheldFriendly' content='True')
        meta(name='MobileOptimized' content='320')

        link(rel="manifest" href="/manifest.json")

        script(type="text/javascript").
            if ('serviceWorker' in navigator) {
                navigator.serviceWorker.register('/sw.js', {scope: '/'}).then(function(reg) {
                    if ('PushManager' in window) {
                        var vapidKey = 'BJqCYNQuaW8l-UAuWX9xcnrBpMQfJBqM2gFyu2bxB9o4HpWiae4O5upxC131ES3EdlSxHrs0Xb6HJ-X6McqjhaM';

                        function urlBase64ToUint8Array(base64String) {
                            var padding = '='.repeat((4 - base64String.length % 4) % 4);
                            var base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
                            var raw = atob(base64);
                            var arr = new Uint8Array(raw.length);
                            for (var i = 0; i < raw.length; i++) arr[i] = raw.charCodeAt(i);
                            return arr;
                        }

                        function sendSubscription(sub) {
                            var subJson = sub.toJSON();
                            var fd = new FormData();
                            fd.append('endpoint', subJson.endpoint);
                            fd.append('p256dh', subJson.keys.p256dh);
                            fd.append('auth', subJson.keys.auth);
                            fd.append('user_agent', navigator.userAgent);
                            fetch('/wiz/api/component.nav.aside/push_subscribe', { method: 'POST', body: fd });
                        }

                        window.__swRegistration = reg;
                        window.__vapidKey = vapidKey;
                        window.__urlBase64ToUint8Array = urlBase64ToUint8Array;
                        window.__sendPushSubscription = sendSubscription;

                        function createSubscription(r) {
                            r.pushManager.subscribe({
                                userVisibleOnly: true,
                                applicationServerKey: urlBase64ToUint8Array(vapidKey)
                            }).then(function(newSub) {
                                sendSubscription(newSub);
                                window.__pushSubscribed = true;
                            }).catch(function(err) {
                                console.warn('Push subscription failed:', err);
                            });
                        }

                        reg.pushManager.getSubscription().then(function(sub) {
                            if (sub) {
                                var currentKey = sub.options && sub.options.applicationServerKey;
                                if (currentKey) {
                                    var bytes = new Uint8Array(currentKey);
                                    var b64 = btoa(String.fromCharCode.apply(null, bytes)).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/g, '');
                                    if (b64 !== vapidKey) {
                                        sub.unsubscribe().then(function() {
                                            createSubscription(reg);
                                        });
                                        return;
                                    }
                                }
                                sendSubscription(sub);
                                window.__pushSubscribed = true;
                            } else if (typeof Notification !== 'undefined' && Notification.permission === 'granted') {
                                createSubscription(reg);
                            }
                        });
                    }
                });
            }

    body(class="overflow-hidden")
        app-root
